#!/bin/bash
# maudebox – launch a maudebox container for a given worktree
#
# Requires the image to already be built via build.sh.
#
# Usage:
#   maudebox [--clean] [--tag TAG] [project-dir] [command...]
#
# Options:
#   --clean   remove the overlay volume for this worktree and exit
#   --tag     image tag to run (default: maudebox)
#
# Examples:
#   maudebox                               # interactive shell in current dir
#   maudebox /path/to/myproject            # interactive shell, specific project
#   maudebox . mvnd verify                 # run a build
#   maudebox . claude                      # start Claude Code
#   maudebox --clean /path/to/myproject    # delete that worktree's overlay volume

set -euo pipefail

IMAGE_NAME="maudebox"
CLEAN=false
MEMORY_FROM=""

usage() {
    cat <<'EOF'
Usage: maudebox [--clean] [--tag TAG] [project-dir] [command...]
       maudebox new <name> [project-dir] [--path PATH] [--from REV] [--keep]

Launch a maudebox container for a host project directory. The project (and
its base repo, if it's a jj workspace or git worktree) is bind-mounted at
its host path inside the container so VCS metadata still resolves. Maven's
local repo is layered: the host's ~/.m2 is exposed read-only beneath a
per-worktree overlay volume so writes stay isolated per worktree.

Options:
  --clean              remove the overlay volume for this worktree and exit
  --tag TAG            image tag to run (default: maudebox)
  --memory-from PATH   share Claude's auto-memory dir with another project
                       (host source keyed to PATH, container target unchanged)
  -h, --help           show this help and exit

Arguments:
  project-dir   host directory to mount (default: current directory)
  command...    command to run inside the container (default: interactive shell)

Subcommands:
  new <name>    create a jj workspace or git worktree from project-dir
                (default: cwd) and launch maudebox on it, sharing the
                parent project's Claude auto-memory dir. By default the
                workspace/worktree and its overlay volume are removed when
                the container exits.
                  --path PATH   target path
                                (default: <project>/../<basename>.<name>)
                  --from REV    starting revision
                                (default: jj @-, git HEAD)
                  --keep        preserve the workspace/worktree and overlay
                                volume after the container exits

Examples:
  maudebox                               # interactive shell in current dir
  maudebox /path/to/myproject            # interactive shell, specific project
  maudebox . mvnd verify                 # run a build
  maudebox . claude                      # start Claude Code
  maudebox --clean /path/to/myproject    # delete that worktree's overlay volume
  maudebox new feature-x                 # ephemeral workspace from cwd
  maudebox new feature-x /path/to/proj   # ephemeral workspace from a project
  maudebox new feature-x --from main     # start from a specific revision
  maudebox new feature-x --keep          # keep workspace/overlay after exit
EOF
}

# ── overlay volume name for a project path ───────────────────────────────────
# Combines the directory basename (human-readable) with a short hash of the
# full path (collision-proof), e.g. maudebox-overlay-myproject-a3f8c21b
compute_volume_name() {
    local dir="$1"
    local dir_name path_hash
    dir_name="$(basename "$dir")"
    path_hash="$(echo "$dir" | sha256sum | cut -c1-8)"
    echo "maudebox-overlay-${dir_name}-${path_hash}"
}

# ── `maudebox new` ────────────────────────────────────────────────────────────
# Create a jj workspace or git worktree from a source project, run maudebox
# on it, and (unless --keep is given) tear down the workspace/worktree and
# its overlay volume on exit. jj is preferred when both .jj and .git are
# present (colocated repos). State for the EXIT trap is held in script-scope
# globals (NEW_*) so the cleanup function can see them when bash fires the
# trap during shell teardown.
NEW_NAME=""; NEW_TARGET=""; NEW_SOURCE=""; NEW_KIND=""; NEW_KEEP=false

cmd_new() {
    local from_rev=""
    NEW_SOURCE="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) usage; exit 0 ;;
            --path)    NEW_TARGET="$2"; shift 2 ;;
            --from)    from_rev="$2";   shift 2 ;;
            --keep)    NEW_KEEP=true;   shift ;;
            -*)        echo "Unknown option: $1" >&2; exit 1 ;;
            *)
                if [ -z "$NEW_NAME" ]; then
                    NEW_NAME="$1"
                elif [ "$NEW_SOURCE" = "." ]; then
                    NEW_SOURCE="$1"
                else
                    echo "Unexpected argument: $1" >&2; exit 1
                fi
                shift
                ;;
        esac
    done

    [ -n "$NEW_NAME" ] || { echo "maudebox new: <name> is required" >&2; exit 1; }

    NEW_SOURCE="$(realpath "$NEW_SOURCE")"
    [ -d "$NEW_SOURCE" ] || { echo "Not a directory: $NEW_SOURCE" >&2; exit 1; }

    if [ -z "$NEW_TARGET" ]; then
        NEW_TARGET="$(dirname "$NEW_SOURCE")/$(basename "$NEW_SOURCE").${NEW_NAME}"
    elif [[ "$NEW_TARGET" != /* ]]; then
        NEW_TARGET="$(pwd)/$NEW_TARGET"
    fi

    [ -e "$NEW_TARGET" ] && { echo "Target path already exists: $NEW_TARGET" >&2; exit 1; }

    if [ -d "$NEW_SOURCE/.jj" ]; then
        NEW_KIND=jj
        echo "Creating jj workspace '$NEW_NAME' at: $NEW_TARGET"
        local jj_args=( workspace add --name "$NEW_NAME" )
        [ -n "$from_rev" ] && jj_args+=( -r "$from_rev" )
        jj_args+=( "$NEW_TARGET" )
        ( cd "$NEW_SOURCE" && jj "${jj_args[@]}" )
    elif [ -e "$NEW_SOURCE/.git" ]; then
        NEW_KIND=git
        local rev="${from_rev:-HEAD}"
        echo "Creating git worktree '$NEW_NAME' at: $NEW_TARGET (branch: $NEW_NAME from $rev)"
        ( cd "$NEW_SOURCE" && git worktree add -b "$NEW_NAME" "$NEW_TARGET" "$rev" )
    else
        echo "Not a jj or git repo: $NEW_SOURCE" >&2
        exit 1
    fi

    if ! $NEW_KEEP; then
        trap _maudebox_new_cleanup EXIT
    fi

    local rc=0
    "$0" --tag "$IMAGE_NAME" --memory-from "$NEW_SOURCE" "$NEW_TARGET" || rc=$?
    exit $rc
}

_maudebox_new_cleanup() {
    local rc=$?
    set +e   # best-effort cleanup
    echo "Cleaning up ephemeral $NEW_KIND workspace at: $NEW_TARGET"
    case "$NEW_KIND" in
        jj)
            ( cd "$NEW_SOURCE" && jj workspace forget "$NEW_NAME" )
            rm -rf "$NEW_TARGET"
            ;;
        git)
            ( cd "$NEW_SOURCE" && git worktree remove --force "$NEW_TARGET" )
            ( cd "$NEW_SOURCE" && git branch -D "$NEW_NAME" )
            ;;
    esac
    local volume
    volume="$(compute_volume_name "$NEW_TARGET")"
    docker volume rm "$volume" >/dev/null 2>&1
    return $rc
}

# ── parse flags ───────────────────────────────────────────────────────────────
while [[ "${1:-}" == --* || "${1:-}" == -h ]]; do
    case "$1" in
        -h|--help)     usage; exit 0 ;;
        --clean)       CLEAN=true;        shift ;;
        --tag)         IMAGE_NAME="$2";   shift 2 ;;
        --memory-from) MEMORY_FROM="$2";  shift 2 ;;
        *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
    esac
done

# ── subcommand dispatch ───────────────────────────────────────────────────────
if [[ "${1:-}" == "new" ]]; then
    shift
    cmd_new "$@"
fi

PROJECT_DIR="$(realpath "${1:-.}")"
shift || true   # remaining args become the container command (default: bash)

# ── detect base repo for jj workspaces / git worktrees ────────────────────────
# A jj workspace stores the absolute or relative path to the *main* repo's
# .jj/repo directory inside <workspace>/.jj/repo (a regular file). A git
# worktree stores `gitdir: <abs-path>` in <worktree>/.git (also a regular
# file). In both cases the worktree's own metadata references an absolute
# host path that won't exist inside the container unless we bind-mount the
# base repo at the same path. detect_vcs_base prints that base path (the
# main repo's working tree, not its .jj/.git dir) or nothing if the project
# isn't a worktree/workspace.
detect_vcs_base() {
    local dir="$1"
    [ -d "$dir" ] || return 0

    if [ -f "$dir/.jj/repo" ]; then
        local content target base
        content="$(cat "$dir/.jj/repo")"
        content="${content%$'\n'}"
        if [[ "$content" == /* ]]; then
            target="$content"
        else
            target="$(cd "$dir/.jj" 2>/dev/null && readlink -f "$content" 2>/dev/null)" || true
        fi
        # target is <main>/.jj/repo; the working tree is two levels up.
        base="${target%/.jj/repo}"
        if [ -n "$target" ] && [ "$base" != "$target" ] && [ "$base" != "$dir" ]; then
            echo "$base"
            return
        fi
    fi

    if [ -f "$dir/.git" ]; then
        local gitdir base
        gitdir="$(grep -m1 '^gitdir:' "$dir/.git" | sed 's|^gitdir: *||')"
        if [[ "$gitdir" != /* ]]; then
            gitdir="$(cd "$dir" 2>/dev/null && readlink -f "$gitdir" 2>/dev/null)" || true
        fi
        # gitdir is typically <main>/.git/worktrees/<name>, sometimes <main>/.git.
        base="${gitdir%/.git/worktrees/*}"
        [ "$base" = "$gitdir" ] && base="${gitdir%/.git}"
        if [ -n "$gitdir" ] && [ "$base" != "$gitdir" ] && [ "$base" != "$dir" ]; then
            echo "$base"
            return
        fi
    fi
}

VCS_BASE="$(detect_vcs_base "$PROJECT_DIR")"

# ── per-worktree volume name ──────────────────────────────────────────────────
UPPER_VOLUME="$(compute_volume_name "$PROJECT_DIR")"

# ── --clean ───────────────────────────────────────────────────────────────────
if $CLEAN; then
    if docker volume inspect "$UPPER_VOLUME" &>/dev/null; then
        docker volume rm "$UPPER_VOLUME"
        echo "Removed volume: $UPPER_VOLUME"
    else
        echo "No volume found for this worktree: $UPPER_VOLUME"
    fi
    exit 0
fi

# ── Claude config: persistent volume + read-only host overlays ────────────────
# maudebox-claude holds writable state (login token, todos, plugin caches) and
# is shared across worktrees so a single `claude` login covers every container.
# Specific files from the host's ~/.claude/ are bind-mounted read-only on top
# so global instructions, settings, agents, commands, and plugin definitions
# come from the host. Items that are keyed to host paths (projects/, todos/,
# statsig/, shell-snapshots/) are intentionally left out.
CLAUDE_AUTH_VOLUME="maudebox-claude"
docker volume create "$CLAUDE_AUTH_VOLUME" > /dev/null

CLAUDE_MOUNTS=( -v "${CLAUDE_AUTH_VOLUME}:/root/.claude" )
HOST_CLAUDE_DIR="$HOME/.claude"
for path in CLAUDE.md settings.json agents commands plugins; do
    if [ -e "$HOST_CLAUDE_DIR/$path" ]; then
        CLAUDE_MOUNTS+=( -v "$HOST_CLAUDE_DIR/$path:/root/.claude/$path:ro" )
    fi
done

# Claude's auto-memory lives at ~/.claude/projects/<encoded-cwd>/memory/, where
# the encoding replaces '/' and '.' in the canonical cwd with '-'. Inside the
# container the project is bind-mounted at its host path, so cwd canonicalizes
# to the same string — meaning host and container normally agree on the key.
# Bind-mount just that one subdir (read-write) so memories written inside the
# container land in the host's ~/.claude/projects/<key>/memory/ and are visible
# to host-side Claude. The rest of projects/<key>/ (session logs, etc.) stays
# in the named volume, consistent with the broader exclusion of projects/.
#
# --memory-from breaks the host/container symmetry: the container target is
# still keyed by PROJECT_DIR (Claude Code derives it from cwd inside the
# container), but the host source is keyed by the override path. `maudebox new`
# uses this so an ephemeral workspace shares its parent project's memory.
PROJECT_KEY="${PROJECT_DIR//\//-}"
PROJECT_KEY="${PROJECT_KEY//./-}"
MEMORY_SOURCE_DIR="${MEMORY_FROM:-$PROJECT_DIR}"
MEMORY_SOURCE_KEY="${MEMORY_SOURCE_DIR//\//-}"
MEMORY_SOURCE_KEY="${MEMORY_SOURCE_KEY//./-}"
HOST_MEMORY_DIR="$HOST_CLAUDE_DIR/projects/$MEMORY_SOURCE_KEY/memory"
mkdir -p "$HOST_MEMORY_DIR"
CLAUDE_MOUNTS+=( -v "$HOST_MEMORY_DIR:/root/.claude/projects/$PROJECT_KEY/memory" )

# ── host git/jj config (read-only) ────────────────────────────────────────────
# Pick up the user's identity, aliases, ignore rules, and jj revset aliases
# (e.g. closest_bookmark) without importing host-local state. We deliberately
# skip ~/.config/jj/repos/ (per-repo cache, host paths) and credential/SSH
# files. Container-incompatible settings like commit.gpgsign are forced off
# in the Dockerfile via GIT_CONFIG_* env vars.
VCS_CONFIG_MOUNTS=()
[ -e "$HOME/.gitconfig" ]               && VCS_CONFIG_MOUNTS+=( -v "$HOME/.gitconfig:/root/.gitconfig:ro" )
[ -d "$HOME/.config/git" ]              && VCS_CONFIG_MOUNTS+=( -v "$HOME/.config/git:/root/.config/git:ro" )
[ -e "$HOME/.config/jj/config.toml" ]   && VCS_CONFIG_MOUNTS+=( -v "$HOME/.config/jj/config.toml:/root/.config/jj/config.toml:ro" )

# ── run ───────────────────────────────────────────────────────────────────────
docker volume create "$UPPER_VOLUME" > /dev/null

# Mount the project (and its base repo, if it's a jj/git worktree) at their
# host paths inside the container so absolute path references in the worktree
# metadata still resolve. The entrypoint adds a /root/<basename> symlink to
# the project for short cd's.
PROJECT_MOUNTS=( -v "${PROJECT_DIR}:${PROJECT_DIR}" )
if [ -n "$VCS_BASE" ] && [ "$VCS_BASE" != "$PROJECT_DIR" ]; then
    PROJECT_MOUNTS+=( -v "${VCS_BASE}:${VCS_BASE}" )
fi

echo "Image    : $IMAGE_NAME"
echo "Worktree : $PROJECT_DIR"
[ -n "$VCS_BASE" ] && [ "$VCS_BASE" != "$PROJECT_DIR" ] && echo "VCS base : $VCS_BASE"
echo "Volume   : $UPPER_VOLUME"

docker run --rm -it \
    --cap-add SYS_ADMIN \
    --security-opt apparmor=unconfined \
    -e "HOST_PROJECT_DIR=$PROJECT_DIR" \
    -v "$HOME/.m2:/m2-host:ro" \
    -v "${UPPER_VOLUME}:/m2-upper" \
    "${PROJECT_MOUNTS[@]}" \
    "${CLAUDE_MOUNTS[@]}" \
    "${VCS_CONFIG_MOUNTS[@]}" \
    "$IMAGE_NAME" \
    "$@"